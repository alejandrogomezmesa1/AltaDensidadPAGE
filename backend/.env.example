# Copy this file to backend/.env and fill values before running

# ---------- MySQL (Conexion) ----------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=altadensidad
DB_USER=root
DB_PASSWORD=changeme

# ---------- Server ----------
PORT=3000
FRONTEND_URL=http://localhost:5500

# ---------- Autenticación / Seguridad ----------
# Secret para firmar JWT (usa un valor fuerte en producción)
JWT_SECRET=tu_jwt_secret_seguro
# Llave opcional para peticiones administrativas (header: x-admin-key)
ADMIN_API_KEY=

# ---------- Mercado Pago ----------
# Token de acceso (sandbox o producción). Si no está definido, el backend
# devolverá preferencias mock para desarrollo local.
MP_ACCESS_TOKEN=
# URL pública donde Mercado Pago enviará notificaciones (webhook)
# Ej: https://your-backend.example.com/api/mercadopago/webhook
MP_NOTIFICATION_URL=
# (Opcional) Secreto compartido para verificar firma HMAC de los webhooks.
# Si lo configuras, el servidor validará la cabecera de firma (p.ej. 'x-hub-signature-256').
MP_WEBHOOK_SECRET=

# ---------- Email (SendGrid) ----------
SENDGRID_API_KEY=

# ---------- Entorno ----------
NODE_ENV=development
# Variables de entorno — copiar a .env y completar valores reales

# Base de datos MySQL (usar un host externo en producción: Railway, PlanetScale, Aiven, etc.)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=altadensidad
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# URL del frontend desplegado (para CORS)
FRONTEND_URL=https://tu-proyecto.vercel.app

# Puerto local
PORT=3000

# Mercado Pago
# Copia tu Access Token de Mercado Pago aquí (modo sandbox o producción)
MP_ACCESS_TOKEN=YOUR_MERCADO_PAGO_ACCESS_TOKEN_HERE
# URL pública del frontend (se usa para back_urls)
FRONTEND_URL=http://localhost:5500
# URL para notificaciones (opcional)
# MP_NOTIFICATION_URL=https://tu-dominio.com/api/mercadopago/webhook
