{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/img/(.*)", "dest": "/assets/img/$1" },
    { "src": "/assets/(.*\\.(css|js|avif|png|jpg|jpeg|gif|webp|svg|ico|woff2?))", "dest": "/assets/$1" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/nosotros", "dest": "/nosotros.html" },
    { "src": "/top10", "dest": "/top10.html" },
    { "src": "/envases", "dest": "/envases.html" },
    { "src": "/reset", "dest": "/reset.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
